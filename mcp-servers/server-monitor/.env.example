# Telegram Configuration
# Get bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# Email/SMTP Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=server-monitor@localhost
# ALERT_EMAIL=admin@example.com

# PostgreSQL Configuration
# DB_NAME=postgres
# DB_USER=postgres
# DB_HOST=localhost
# DB_PORT=5432

# Alert Thresholds
# THRESHOLD_CPU=85
# THRESHOLD_MEM=90
# THRESHOLD_DISK=80
# THRESHOLD_SWAP=50
# THRESHOLD_ZOMBIES=5
# THRESHOLD_DB_CONNECTIONS=80

# Timing Configuration (in milliseconds)
# CHECK_INTERVAL=300000 (5 minutes)
# ALERT_COOLDOWN=1800000 (30 minutes)
# DAILY_REPORT_HOUR=8

# Cleanup Configuration
# AUTO_CLEAN=false
# CLEAN_LOGS_DAYS=30

# Log file location
# LOG_FILE=/var/log/server-monitor/alerts.log
